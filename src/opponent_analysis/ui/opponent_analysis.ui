<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="OpponentAnalysis" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <property name="margin-top">12</property>
    <property name="margin-bottom">12</property>
    <property name="margin-start">12</property>
    <property name="margin-end">12</property>

    <!-- Header / Controls -->
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Team:</property>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="dropdown_team">
            <property name="enable-search">true</property>
          </object>
        </child>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Num. of Matches:</property>
          </object>
        </child>
        <child>
          <object class="GtkSpinButton" id="spin_limit">
            <property name="adjustment">
              <object class="GtkAdjustment">
                <property name="lower">1</property>
                <property name="upper">25</property>
                <property name="value">10</property>
                <property name="step-increment">1</property>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Match types:</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="check_league">
            <property name="label" translatable="yes">League</property>
            <property name="active">true</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="check_cup">
            <property name="label" translatable="yes">Cup</property>
            <property name="active">true</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="check_friendly">
            <property name="label" translatable="yes">Friendly</property>
            <property name="active">false</property>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="check_international">
            <property name="label" translatable="yes">International</property>
            <property name="active">true</property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="btn_analyze">
            <property name="label" translatable="yes">Analyse &amp; Optimize</property>
            <property name="css-classes">suggested-action</property>
          </object>
        </child>

        <child>
          <object class="GtkSpinner" id="spinner">
            <property name="spinning">false</property>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkSeparator"/>
    </child>

    <!-- Results Area -->
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>
        <property name="vexpand">true</property>
        
        <!-- Left Pane: Match List -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="width-request">300</property>

            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">&lt;b&gt;Matches&lt;/b&gt;</property>
                <property name="use-markup">true</property>
                <property name="xalign">0</property>
              </object>
            </child>

            <child>
              <object class="GtkScrolledWindow">
                <property name="vexpand">true</property>
                <property name="hexpand">true</property>
                <child>
                  <object class="GtkListView" id="match_list_view">
                    <!-- The model and factory will be set in Rust code -->
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Separator between panes -->
        <child>
          <object class="GtkSeparator">
            <property name="orientation">vertical</property>
          </object>
        </child>

        <!-- Right Pane: Details & Pitch -->
        <child>
          <object class="GtkScrolledWindow">
            <property name="vexpand">true</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">16</property>
                <property name="margin-start">12</property>

                <!-- Statistics area -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">24</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">&lt;b&gt;Formations Used:&lt;/b&gt;</property>
                            <property name="use-markup">true</property>
                            <property name="xalign">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_formations">
                            <property name="label" translatable="yes">No data yet.</property>
                            <property name="xalign">0</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">&lt;b&gt;Average Sector Ratings:&lt;/b&gt;</property>
                            <property name="use-markup">true</property>
                            <property name="xalign">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="average_ratings_pitch">
                            <!-- PitchView will be inserted here dynamically -->
                            <property name="orientation">vertical</property>
                            <property name="vexpand">true</property>
                            <property name="hexpand">true</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="lbl_tactical_summary">
                            <property name="label" translatable="yes">Calculating tendencies...</property>
                            <property name="use-markup">true</property>
                            <property name="xalign">0</property>
                            <property name="wrap">true</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <!-- Match Projection Area -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Match Projection vs Current Lineup:&lt;/b&gt;</property>
                        <property name="use-markup">true</property>
                        <property name="xalign">0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel" id="lbl_prediction">
                            <property name="label" translatable="yes">Load an opponent to see win probability.</property>
                            <property name="xalign">0</property>
                            <property name="hexpand">true</property>
                            <property name="use-markup">true</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkProgressBar" id="pb_win_prob">
                        <property name="show-text">true</property>
                        <property name="fraction">0.0</property>
                      </object>
                    </child>
                  </object>
                </child>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Injured/Suspended Players:&lt;/b&gt;</property>
                        <property name="use-markup">true</property>
                        <property name="xalign">0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="lbl_unavailable">
                        <property name="label" translatable="yes">No data yet.</property>
                        <property name="xalign">0</property>
                        <property name="wrap">true</property>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- Pitch visualization for selected match -->
                <child>
                  <object class="GtkSeparator"/>
                </child>
                <child>
                   <object class="GtkLabel">
                     <property name="label" translatable="yes">&lt;b&gt;Match Lineup&lt;/b&gt;</property>
                     <property name="use-markup">true</property>
                     <property name="xalign">0</property>
                   </object>
                </child>
                <child>
                   <object class="GtkBox" id="pitch_container">
                     <!-- PitchView will be inserted here dynamically -->
                     <property name="orientation">vertical</property>
                     <property name="vexpand">true</property>
                     <property name="hexpand">true</property>
                   </object>
                </child>

              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
